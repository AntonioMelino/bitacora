{
  "$schema": "https://schema.railpack.com",
  "provider": "dotnet",
  "packages": {
    "dotnet": "10"
  },
  "steps": {
    "install": {
      "commands": ["echo 'restore runs in the build step, after full source is available'"]
    },
    "build": {
      "commands": [
        "dotnet restore Bitacora.API/Bitacora.API.csproj",
        "dotnet publish Bitacora.API/Bitacora.API.csproj -c Release -o out --no-restore"
      ]
    }
  },
  "deploy": {
    "startCommand": "dotnet out/Bitacora.API.dll"
  }
}
