{
  "$schema": "https://schema.railpack.com",
  "provider": "dotnet",
  "packages": {
    "dotnet": "10"
  },
  "steps": {
    "install": {
      "commands": ["dotnet restore Bitacora.API/Bitacora.API.csproj"]
    },
    "build": {
      "commands": ["dotnet publish Bitacora.API/Bitacora.API.csproj -c Release -o out --no-restore"]
    }
  },
  "deploy": {
    "startCommand": "dotnet out/Bitacora.API.dll"
  }
}
